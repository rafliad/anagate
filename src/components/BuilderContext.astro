---
import { builderPoints } from "../content/landing";
---

<section class="builder section-shell" aria-labelledby="builder-title">
  <div class="builder-panel" data-reveal>
    <div>
      <h2 id="builder-title">Stellar-native controls for agent payment surfaces.</h2>
      <p class="builder-intro">
        The concept is early, but the operating model is specific: structured payment
        requests, a policy decision, and a relayer that signs only when allowed.
      </p>
    </div>
    <ul class="builder-features">
      {builderPoints.map((point) => (
        <li>
          <strong>{point.label}</strong>
          {point.body}
        </li>
      ))}
    </ul>
  </div>
</section>
