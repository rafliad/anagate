---
import { decisionStates } from "../content/landing";
---

<section class="decisions section-shell" aria-labelledby="decision-title">
  <div class="section-heading-center" data-reveal>
    <h2 id="decision-title">Every request exits through one explicit state.</h2>
  </div>
  <div class="decision-strip" data-reveal style="--reveal-delay: 0.15s">
    {decisionStates.map((decision) => (
      <article class={`decision-card decision-${decision.state.toLowerCase()}`}>
        <span class="decision-label">{decision.label}</span>
        <h3>{decision.state}</h3>
        <p>{decision.body}</p>
      </article>
    ))}
  </div>
</section>
