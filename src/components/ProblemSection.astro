---
import { failurePatterns, problems } from "../content/landing";
---

<section class="problem section-shell" aria-labelledby="problem-title">
  <div class="section-heading" data-reveal>
    <h2 id="problem-title">Payment safety has to happen before execution.</h2>
    <p class="section-copy">
      Agent payments need a narrow signing path: enough autonomy to move, with policy checks
      before money can leave the wallet.
    </p>
  </div>
  <div class="problem-list" data-reveal style="--reveal-delay: 0.15s">
    {problems.map((item) => (
      <article class="problem-item">
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </article>
    ))}
  </div>
  <div class="pattern-block" data-reveal style="--reveal-delay: 0.25s" aria-label="Failure patterns without a policy gate">
    <p class="pattern-kicker">What goes wrong without a gate</p>
    <div class="pattern-list">
      {failurePatterns.map((pattern) => (
        <article class="pattern-item">
          <h3>{pattern.title}</h3>
          <p>{pattern.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
