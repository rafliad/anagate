---
import { navItems, site } from "../content/landing";
---

<footer class="site-footer">
  <div>
    <a class="brand" href="#top" aria-label="Anagate home">
      <img src="/anagate-logo.png" alt="" width="32" height="32" />
      <span>{site.name}</span>
    </a>
    <p>Pre-signing policy enforcement for AI-agent payments on Stellar.</p>
  </div>
  <nav aria-label="Footer navigation">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</footer>
